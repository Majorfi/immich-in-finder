# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# Base URL of your Immich server, WITHOUT a trailing /api.
# Example: https://photos.mydomain.com
IMMICH_BASE_URL=https://immich.example.com

# API key: Immich web UI -> Account Settings -> API Keys -> New API Key.
IMMICH_API_KEY=replace-me

# Optional: pin a specific album to probe. Leave empty to use the first album.
IMMICH_ALBUM_ID=

# Optional: thumbnail size. Leave empty to use the server default. Only set this
# if the thumbnail request returns an HTTP error asking for a size.
IMMICH_THUMB_SIZE=
